---
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title type="text"><%= site.metadata.title %></title>
  <subtitle><%= site.metadata.description.to_s.strip %></subtitle>
  <link href="<%= site.metadata.url %>/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="<%= site.metadata.url %>/" rel="alternate" type="text/html"/>
  <updated><%= site.collections.posts.resources.map(&:date).max&.iso8601 %></updated>
  <id><%= site.metadata.url %>/feed.xml</id>
  <author>
    <name><%= site.metadata.author %></name>
  </author>
  <% site.collections.posts.resources.sort_by(&:date).reverse.first(20).each do |post| %>
  <entry>
    <title type="html"><%= post.data.title.to_s.encode(xml: :text) %></title>
    <link href="<%= site.metadata.url %><%= post.relative_url %>" rel="alternate" type="text/html"/>
    <id><%= site.metadata.url %><%= post.relative_url %></id>
    <published><%= post.date.iso8601 %></published>
    <updated><%= (post.data.last_modified_at || post.date).to_time.iso8601 %></updated>
    <% if post.data.description %>
    <summary type="html"><%= post.data.description.to_s.encode(xml: :text) %></summary>
    <% end %>
    <content type="html"><%= post.content.to_s.encode(xml: :text) %></content>
    <author>
      <name><%= site.metadata.author %></name>
    </author>
    <% Array(post.data.tags).each do |tag| %>
    <category term="<%= tag %>"/>
    <% end %>
  </entry>
  <% end %>
</feed>

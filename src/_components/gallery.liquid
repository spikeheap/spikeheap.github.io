{%- comment -%}
Minimal gallery include — replaces minimal-mistakes' equivalent.
Reads an array from page frontmatter (default `page.gallery`, override with
`id` parameter) and renders a flexbox grid of images with optional caption.
{%- endcomment -%}
{%- assign gallery_id = include.id | default: "gallery" -%}
{%- assign images = page[gallery_id] -%}
{%- if images -%}
<figure class="gallery">
  <div class="gallery__items">
    {%- for image in images -%}
    <a href="{{ image.url | relative_url }}" class="gallery__item">
      <img src="{{ image.image_path | relative_url }}" alt="{{ image.alt | escape }}" title="{{ image.title | escape }}" loading="lazy">
    </a>
    {%- endfor -%}
  </div>
  {%- if include.caption -%}
  <figcaption>{{ include.caption }}</figcaption>
  {%- endif -%}
</figure>
{%- endif -%}
